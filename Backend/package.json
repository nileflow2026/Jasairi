{
  "name": "@jasiri/backend",
  "version": "1.0.0",
  "description": "Jasiri Learning App Backend API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --watch .env --ext js,mjs,cjs,json src/server.js",
    "build": "npm run copy:assets",
    "start": "node src/server.js",
    "setup": "node scripts/setup.js",
    "setup:games": "node scripts/setup-game-collections.js",
    "setup:db": "node scripts/setup-all-collections.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "clean": "rm -rf node_modules coverage",
    "copy:assets": "cp -r src/assets uploads/ || true",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "node src/database/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-appwrite": "^13.0.0",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.6.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "nodejs",
    "express",
    "api",
    "backend",
    "assistive-technology",
    "education"
  ],
  "author": "Jasiri Learning Team",
  "license": "PROPRIETARY"
}
