# ──────────────────────────────────────────────────────────────────────────────
# JASIRI Backend — Production Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit a populated .env to git.
# Generate secrets: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
API_VERSION=v1

# ── Appwrite ──────────────────────────────────────────────────────────────────
# Use the PRODUCTION Appwrite project only.
# Create a dedicated API key with minimum required scopes (see DEPLOYMENT.md).
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=REPLACE_WITH_PROD_PROJECT_ID
APPWRITE_API_KEY=REPLACE_WITH_PROD_API_KEY

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Rotate every 90 days.
# openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis ─────────────────────────────────────────────────────────────────────
# Use rediss:// (TLS) in production, not redis://
REDIS_URL=rediss://REPLACE_WITH_REDIS_HOST:6380
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list. No trailing slashes. No wildcards in production.
# Include only your Expo Go domain and any web deployment origin.
CORS_ORIGIN=https://api.jasiri.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────────────────────────
# Use 'info' in production — never 'debug' (sensitive data may leak)
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_FILE_SIZE=10mb
UPLOAD_FOLDER=uploads

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN
ANALYTICS_ENABLED=true

# ── Child Safety ──────────────────────────────────────────────────────────────
MAX_CHILDREN_PER_GUARDIAN=5
SESSION_TIMEOUT_MINUTES=30
CONTENT_MODERATION_ENABLED=true

# ── AI Service (if applicable) ────────────────────────────────────────────────
AI_SERVICE_URL=REPLACE_IF_USING_EXTERNAL_AI
AI_API_KEY=REPLACE_IF_USING_EXTERNAL_AI
